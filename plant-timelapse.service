[Unit]
Description=Plant Timelapse Monitor
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pato/plant-timelapse/app.py
WorkingDirectory=/home/pato/plant-timelapse
User=pato
Restart=always
RestartSec=5
# Give the camera stack time to initialize on boot
ExecStartPre=/bin/sleep 3

[Install]
WantedBy=multi-user.target
